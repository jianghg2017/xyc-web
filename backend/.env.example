# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=company_website

# JWT 配置
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# 默认管理员账户
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=Admin@123456

# AI 智能助手 - 大模型服务配置
# 支持 OpenAI 兼容格式的 API（DeepSeek、Kimi、智谱 AI、通义千问等）

# === Kimi API (月之暗面 Moonshot AI) ===
# 注册地址: https://platform.moonshot.cn/
# LLM API 端点地址（必填）
LLM_API_URL=https://api.moonshot.cn/v1/chat/completions
# LLM API 认证密钥（必填）
LLM_API_KEY=
# 模型名称（可选，默认为 moonshot-v1-8k）
# 可选模型: moonshot-v1-8k, moonshot-v1-32k, moonshot-v1-128k
LLM_MODEL_NAME=moonshot-v1-8k

# === 其他 LLM 服务配置示例 ===

# DeepSeek (推荐，性价比高)
# LLM_API_URL=https://api.deepseek.com/v1/chat/completions
# LLM_API_KEY=你的DeepSeek_API_Key
# LLM_MODEL_NAME=deepseek-chat

# 智谱 AI (GLM-4)
# LLM_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
# LLM_API_KEY=你的智谱_API_Key
# LLM_MODEL_NAME=glm-4

# OpenAI
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=你的OpenAI_API_Key
# LLM_MODEL_NAME=gpt-3.5-turbo

# 阿里云通义千问
# LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# LLM_API_KEY=你的通义千问_API_Key
# LLM_MODEL_NAME=qwen-turbo
